@inject IAuthService Auth

<div class="login-page">
    <div class="login-card">
        <h1 class="login-title">DunIt</h1>
        @if (error.Length > 0)
        {
            <p class="login-error">@error</p>
        }
        <button class="login-btn" @onclick="HandleSignIn" disabled="@busy">Sign in with Google</button>
    </div>
</div>

@code {
    private string error = string.Empty;
    private bool busy;

    private async Task HandleSignIn()
    {
        busy = true;
        error = string.Empty;
        StateHasChanged();
        var ok = await Auth.SignIn();
        if (!ok)
            error = "Sign-in failed or was cancelled.";
        busy = false;
    }
}
