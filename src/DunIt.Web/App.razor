@using DunIt.Core.Auth
@using DunIt.Web.Pages
@inject IAuthService Auth
@implements IDisposable

@if (Auth.IsAuthenticated)
{
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <p>Sorry, there's nothing at this address.</p>
        </NotFound>
    </Router>
}
else
{
    <Login />
}

@code {
    protected override void OnInitialized() => Auth.AuthStateChanged += OnAuthStateChanged;

    protected override async Task OnInitializedAsync() => await Auth.RestoreSession();

    public void Dispose() => Auth.AuthStateChanged -= OnAuthStateChanged;

    private void OnAuthStateChanged() => InvokeAsync(StateHasChanged);
}
